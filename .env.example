PLUGGY_CLIENT_ID=your-client-id
PLUGGY_CLIENT_SECRET=your-client-secret
PLUGGY_API_KEY=

PLUGGY_USE_SANDBOX=true

# Auto-sync do Pluggy: ao abrir o app + a cada AUTO_SYNC_MINUTES (0 desativa o periódico)
AUTO_SYNC_ON_START=true
AUTO_SYNC_MINUTES=30
AUTO_SYNC_DAYS=30

# Login (Basic Auth). VAZIO = sem login (uso local). Para acesso online, defina uma senha forte.
APP_USER=familia
APP_PASSWORD=

DATABASE_URL=sqlite:///data/financas.db

# PostgreSQL foundation (optional until the multi-family cutover)
# To run locally: docker compose --profile postgres up -d postgres
# Keep DATABASE_URL as SQLite until the migration cutover is explicitly executed.
# Set POSTGRES_PASSWORD before running the postgres profile.
POSTGRES_DB=deon_fin
POSTGRES_USER=deon_fin
POSTGRES_PASSWORD=
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# DATABASE_URL=postgresql://deon_fin:<POSTGRES_PASSWORD>@postgres:5432/deon_fin

# Auth/session pepper for hashed audit identifiers and tokens.
AUTH_PEPPER=
# Optional auth/session database. Use this to enable the new login while keeping financial data on SQLite.
# AUTH_DATABASE_URL=postgresql://deon_fin:<POSTGRES_PASSWORD>@postgres:5432/deon_fin
# Backend session gate. Keep false until AUTH_DATABASE_URL points to PostgreSQL and the frontend is built with NEXT_PUBLIC_AUTH_ENABLED=true.
AUTH_SESSION_ENABLED=false

LOG_LEVEL=INFO

# Origens liberadas para o frontend em desenvolvimento (separadas por vírgula)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Análise por IA — provedor: anthropic | openrouter | ollama | gemini | zai | openai
ANALYST_PROVIDER=openrouter
# Chave do provedor escolhido (use a variável correspondente):
#   OPENROUTER_API_KEY / ANTHROPIC_API_KEY / GEMINI_API_KEY / ZAI_API_KEY / Z_API_KEY / OPENAI_API_KEY
# Ou ANALYST_API_KEY genérica para qualquer provedor.
# Ollama é local e não precisa de chave.
OPENROUTER_API_KEY=
ZAI_API_KEY=
Z_API_KEY=
# Modelo do provedor (ex.: anthropic/claude-sonnet-4.5 no OpenRouter,
# claude-opus-4-8 no Anthropic, llama3.1:8b no Ollama)
ANALYST_MODEL=anthropic/claude-sonnet-4.5
# Renda mensal líquida (número) e objetivos separados por vírgula
MONTHLY_INCOME=
FINANCIAL_GOALS=reserva de emergência,quitar dívidas,investir,viagem
