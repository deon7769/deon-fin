PLUGGY_CLIENT_ID=your-client-id
PLUGGY_CLIENT_SECRET=your-client-secret
PLUGGY_API_KEY=

PLUGGY_USE_SANDBOX=true

# Auto-sync do Pluggy: ao abrir o app + a cada AUTO_SYNC_MINUTES (0 desativa o periódico)
AUTO_SYNC_ON_START=true
AUTO_SYNC_MINUTES=360
AUTO_SYNC_DAYS=30

# Login (Basic Auth). VAZIO = sem login (uso local). Para acesso online, defina uma senha forte.
APP_USER=familia
APP_PASSWORD=

DATABASE_URL=sqlite:///data/financas.db

LOG_LEVEL=INFO

# Análise por IA — provedor: anthropic | openrouter | ollama | gemini | zai | openai
ANALYST_PROVIDER=openrouter
# Chave do provedor escolhido (use a variável correspondente):
#   OPENROUTER_API_KEY / ANTHROPIC_API_KEY / GEMINI_API_KEY / ZAI_API_KEY / OPENAI_API_KEY
# Ollama é local e não precisa de chave.
OPENROUTER_API_KEY=
# Modelo do provedor (ex.: anthropic/claude-sonnet-4.5 no OpenRouter,
# claude-opus-4-8 no Anthropic, llama3.1:8b no Ollama)
ANALYST_MODEL=anthropic/claude-sonnet-4.5
# Renda mensal líquida (número) e objetivos separados por vírgula
MONTHLY_INCOME=
FINANCIAL_GOALS=reserva de emergência,quitar dívidas,investir,viagem
